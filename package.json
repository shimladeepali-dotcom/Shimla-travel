{
  "name": "shimla-travel",
  "version": "1.0.0",
  "description": "Tour package booking website",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web & npm run dev --workspace=apps/api",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/api",
    "test": "npm test --workspaces",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:migrate": "npm run migrate --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
